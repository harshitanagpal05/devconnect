<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main class="main-content">
    <article class="post-detail" id="post-detail-<%= post._id %>">
        <div class="post-detail-header">
            <a href="/posts" class="back-link" id="back-to-feed">
                <span class="arrow">←</span>
                Back to Feed
            </a>

            <div class="post-detail-meta">
                <span class="post-author-large">
                    <span class="author-avatar author-avatar-lg"><%= post.author ? post.author.charAt(0).toUpperCase() : 'A' %></span>
                    <span class="author-info">
                        <strong><%= post.author || 'Anonymous' %></strong>
                        <span class="post-date-detail">
                            <%= new Date(post.createdAt).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' }) %>
                            · <%= Math.max(1, Math.ceil(post.content.split(' ').length / 200)) %> min read
                        </span>
                    </span>
                </span>
            </div>

            <h1 class="post-detail-title"><%= post.title %></h1>
        </div>

        <div class="post-detail-content" id="post-content">
            <% const paragraphs = post.content.split('\n').filter(p => p.trim()); %>
            <% paragraphs.forEach(paragraph => { %>
                <p><%= paragraph %></p>
            <% }); %>
        </div>

        <!-- Social Actions Bar -->
        <div class="social-bar">
            <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                <% const hasLiked = post.likes && post.likes.includes(currentUser.username); %>
                <form action="/posts/<%= post._id %>/like" method="POST" class="inline-form">
                    <button type="submit" class="btn btn-like <%= hasLiked ? 'liked' : '' %>" id="like-btn">
                        <%= hasLiked ? '❤️' : '🤍' %> <%= post.likes ? post.likes.length : 0 %>
                    </button>
                </form>
            <% } else { %>
                <span class="btn btn-like" style="cursor:default">🤍 <%= post.likes ? post.likes.length : 0 %></span>
            <% } %>

            <button class="btn btn-share" id="share-btn" onclick="sharePost()">🔗 Share</button>

            <span style="margin-left:auto;font-size:.78rem;color:var(--t3)">
                💬 <%= post.comments ? post.comments.length : 0 %> comments
            </span>
        </div>

        <!-- Edit / Delete for logged-in users -->
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
            <div class="post-detail-actions" id="post-actions">
                <a href="/posts/<%= post._id %>/edit" class="btn btn-secondary" id="edit-post-btn">
                    ✏️ Edit
                </a>
                <form action="/posts/<%= post._id %>/delete" method="POST" class="inline-form" id="delete-post-form"
                      onsubmit="return confirm('Are you sure you want to delete this post?')">
                    <button type="submit" class="btn btn-danger" id="delete-post-btn">
                        🗑️ Delete
                    </button>
                </form>
            </div>
        <% } %>

        <% if (post.updatedAt && post.updatedAt.toString() !== post.createdAt.toString()) { %>
            <div class="post-updated-note">
                <em>Last updated: <%= new Date(post.updatedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></em>
            </div>
        <% } %>

        <!-- Comments Section -->
        <div class="comments-section" id="comments-section">
            <h3 class="comments-title">
                Comments <span><%= post.comments ? post.comments.length : 0 %></span>
            </h3>

            <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                <form action="/posts/<%= post._id %>/comment" method="POST" class="comment-form" id="comment-form">
                    <input type="text" name="text" class="form-input" placeholder="Write a comment..." required maxlength="500" autocomplete="off">
                    <button type="submit" class="btn btn-primary">Post</button>
                </form>
            <% } else { %>
                <p style="font-size:.85rem;color:var(--t3);margin-bottom:18px"><a href="/users/login" class="auth-switch-link">Sign in</a> to leave a comment.</p>
            <% } %>

            <% if (post.comments && post.comments.length > 0) { %>
                <div class="comment-list">
                    <% post.comments.slice().reverse().forEach(c => { %>
                        <div class="comment-item">
                            <div class="comment-meta">
                                <span class="author-avatar" style="width:22px;height:22px;font-size:.6rem"><%= c.author.charAt(0).toUpperCase() %></span>
                                <strong><%= c.author %></strong>
                                <span>· <%= new Date(c.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
                            </div>
                            <p class="comment-text"><%= c.text %></p>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </div>
    </article>
</main>

<script>
function sharePost() {
    const url = window.location.href;
    if (navigator.share) {
        navigator.share({ title: document.title, url });
    } else {
        navigator.clipboard.writeText(url).then(() => {
            const btn = document.getElementById('share-btn');
            btn.textContent = '✅ Copied!';
            setTimeout(() => { btn.textContent = '🔗 Share'; }, 2000);
        });
    }
}
</script>

<%- include('partials/footer') %>
