    <footer class="footer" id="main-footer">
        <div class="footer-container">
            <div class="footer-brand">
                <span class="brand-icon">⟨/⟩</span>
                <span>Dev<span class="brand-accent">Connect</span></span>
            </div>
            <p class="footer-text">Built with ❤️ for developers, by developers.</p>
            <p class="footer-copy">&copy; <%= new Date().getFullYear() %> DevConnect. All rights reserved.</p>
        </div>
    </footer>

    <script>
        // Page load animation
        document.addEventListener('DOMContentLoaded', () => {
            document.body.classList.add('page-loaded');
        });

        // Auto-dismiss flash messages
        document.querySelectorAll('.flash').forEach(el => {
            setTimeout(() => {
                el.style.transition = 'all 0.5s cubic-bezier(.4,0,.2,1)';
                el.style.opacity = '0';
                el.style.transform = 'translateY(-14px) scale(.95)';
                setTimeout(() => el.remove(), 500);
            }, 4000);
        });

        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('main-navbar');
            if (window.scrollY > 20) {
                nav.classList.add('nav-scrolled');
            } else {
                nav.classList.remove('nav-scrolled');
            }
        }, { passive: true });

        // Scroll-reveal with stagger for all animated elements
        if ('IntersectionObserver' in window) {
            const animEls = document.querySelectorAll('.post-card, .comment-item, .section-header, .empty-state, .post-detail, .form-card, .login-card, .error-card');
            animEls.forEach(el => {
                el.classList.add('reveal-hidden');
            });
            let revealDelay = 0;
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        revealDelay += 100;
                        setTimeout(() => {
                            entry.target.classList.add('reveal-visible');
                            entry.target.classList.remove('reveal-hidden');
                        }, revealDelay);
                        observer.unobserve(entry.target);
                        setTimeout(() => { revealDelay = 0; }, 800);
                    }
                });
            }, { threshold: 0.05, rootMargin: '0px 0px -30px 0px' });
            animEls.forEach(el => observer.observe(el));
        }

        // Button ripple effect
        document.querySelectorAll('.btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                const ripple = document.createElement('span');
                const rect = this.getBoundingClientRect();
                const size = Math.max(rect.width, rect.height) * 2;
                const x = e.clientX - rect.left - size / 2;
                const y = e.clientY - rect.top - size / 2;
                ripple.style.cssText = `position:absolute;border-radius:50%;background:rgba(255,255,255,.25);pointer-events:none;width:${size}px;height:${size}px;left:${x}px;top:${y}px;animation:btn-ripple .6s ease-out forwards;z-index:10`;
                this.appendChild(ripple);
                setTimeout(() => ripple.remove(), 700);
            });
        });

        // Smooth page transitions
        document.querySelectorAll('a:not([target]):not([href^="#"]):not([onclick])').forEach(link => {
            link.addEventListener('click', function(e) {
                const href = this.getAttribute('href');
                if (href && href.startsWith('/')) {
                    e.preventDefault();
                    const overlay = document.getElementById('page-transition');
                    overlay.classList.add('page-transition-active');
                    setTimeout(() => { window.location.href = href; }, 300);
                }
            });
        });

        // Parallax on mouse move for hero decorations
        const hero = document.querySelector('.hero-decoration');
        if (hero) {
            document.addEventListener('mousemove', (e) => {
                const x = (e.clientX / window.innerWidth - 0.5) * 20;
                const y = (e.clientY / window.innerHeight - 0.5) * 20;
                hero.style.transform = `translate(${x}px, ${y}px)`;
            });
        }

        // Tilt effect on post cards
        document.querySelectorAll('.post-card').forEach(card => {
            card.addEventListener('mousemove', function(e) {
                const rect = this.getBoundingClientRect();
                const x = ((e.clientX - rect.left) / rect.width - 0.5) * 8;
                const y = ((e.clientY - rect.top) / rect.height - 0.5) * -8;
                this.style.transform = `translateY(-8px) scale(1.02) perspective(1000px) rotateY(${x}deg) rotateX(${y}deg)`;
            });
            card.addEventListener('mouseleave', function() {
                this.style.transform = '';
            });
        });
    </script>
</body>
</html>
