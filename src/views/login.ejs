<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main class="main-content">
    <div class="login-container" id="login-container">
        <div class="login-card">
            <div class="login-card-glow"></div>
            <div class="login-header">
                <div class="login-icon">
                    <span>⟨/⟩</span>
                </div>
                <h1 class="login-title">Welcome Back</h1>
                <p class="login-subtitle">Sign in to your DevConnect account</p>
            </div>

            <form action="/users/login/web" method="POST" class="login-form" id="login-form">
                <div class="form-group" id="form-group-username">
                    <label for="username" class="form-label">Username</label>
                    <div class="input-wrapper">
                        <span class="input-icon">👤</span>
                        <input
                            type="text"
                            id="username"
                            name="username"
                            class="form-input"
                            placeholder="Enter your username"
                            required
                            autocomplete="username"
                        >
                        <span class="input-focus-line"></span>
                    </div>
                </div>

                <div class="form-group" id="form-group-password">
                    <label for="password" class="form-label">Password</label>
                    <div class="input-wrapper">
                        <span class="input-icon">🔒</span>
                        <input
                            type="password"
                            id="password"
                            name="password"
                            class="form-input"
                            placeholder="Enter your password"
                            required
                            autocomplete="current-password"
                        >
                        <span class="input-focus-line"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-login" id="login-submit">
                    <span>Sign In</span>
                    <span class="btn-shine"></span>
                </button>
            </form>

            <div class="login-hint">
                <p>Don't have an account? <a href="/users/signup" class="auth-switch-link">Sign Up for free</a></p>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
